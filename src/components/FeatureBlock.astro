---
import type { ImageMetadata } from 'astro';
import BrowserFrame from './BrowserFrame.astro';

interface Props {
  image: ImageMetadata;
  title: string;
  description: string;
  reverse?: boolean;
}

const { image, title, description, reverse = false } = Astro.props;
---

<section class:list={['feature', 'fade-in', { reverse }]}>
  <div class="container feature-grid">
    <div class="feature-media">
      <BrowserFrame>
        <img src={image.src} alt={title} width={image.width} height={image.height} loading="lazy" />
      </BrowserFrame>
    </div>
    <div class="feature-body">
      <h3 class="feature-title">{title}</h3>
      <p class="feature-desc">{description}</p>
    </div>
  </div>
</section>

<style>
  .feature {
    padding: clamp(2rem, 4vw, 3.5rem) 0;
  }

  .feature-grid {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .feature-grid {
      grid-template-columns: 7fr 5fr;
    }

    .reverse .feature-grid {
      grid-template-columns: 5fr 7fr;
    }

    .reverse .feature-media {
      order: 2;
    }
  }

  .feature-title {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    line-height: 1.3;
  }

  .feature-desc {
    margin-top: 0.75rem;
    color: var(--color-subtext);
    line-height: 1.7;
  }
</style>
