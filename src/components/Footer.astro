---
import logo from '../assets/images/foxry-logo.png';
---

<footer class="footer">
  <div class="container footer-inner">
    <a href="/" class="footer-logo-link" aria-label="Foxry Home">
      <img src={logo.src} alt="Foxry" class="footer-logo" width={logo.width} height={logo.height} />
    </a>
    <nav class="footer-meta" aria-label="Footer">
      <address class="contact">
        <a href="mailto:foxry.support@gmail.com">foxry.support@gmail.com</a>
      </address>
      <nav class="footer-links" aria-label="Legal">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </nav>
      <a href="https://thesaasdir.com/product/retainpulse?ref=badge" rel="dofollow" class="badge-link">
        <img src="https://thesaasdir.com/badge/retainpulse.svg" alt="Featured on TheSaaSDir" width="160" height="44" />
      </a>
      <p class="copyright">&copy; 2026 Foxry</p>
    </nav>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-3xl) 0 var(--space-2xl);
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .footer-inner {
      align-items: flex-start;
      text-align: left;
    }
  }

  .footer-logo-link {
    display: inline-block;
    transition: opacity 0.2s ease;
    cursor: pointer;
  }

  .footer-logo-link:hover {
    opacity: 0.7;
  }

  .footer-logo {
    height: 3.5rem;
    width: auto;
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  @media (min-width: 768px) {
    .footer-meta {
      align-items: flex-start;
    }
  }

  address {
    font-style: normal;
  }

  .footer-meta a {
    transition: color 0.2s ease;
    cursor: pointer;
  }

  .footer-meta a:hover {
    color: var(--color-accent);
  }

  .footer-links {
    display: flex;
    gap: var(--space-sm);
  }

  .footer-links a + a::before {
    content: "·";
    margin-right: var(--space-sm);
  }

  .badge-link {
    display: inline-block;
    transition: opacity 0.2s ease;
    cursor: pointer;
  }

  .badge-link:hover {
    opacity: 0.7;
  }

  .copyright {
    color: var(--color-muted);
  }
</style>
