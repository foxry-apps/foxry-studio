---
import logo from '../assets/images/foxry-logo.png';
---

<header class="header">
  <nav class="container">
    <a href="/" class="logo-link" aria-label="Foxry Home">
      <img src={logo.src} alt="Foxry" class="logo" width={logo.width} height={logo.height} />
    </a>
  </nav>
</header>

<style>
  .header {
    background-color: var(--color-surface);
    padding: var(--space-md) 0;
  }

  .logo-link {
    display: inline-block;
    transition: opacity 0.2s ease;
    cursor: pointer;
  }

  .logo-link:hover {
    opacity: 0.7;
  }

  .logo {
    height: 2.5rem;
    width: auto;
  }
</style>
