---
import featureImage from '../assets/images/01_feature_image.png';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-body">
      <h1 class="hero-title">
        Smarter tools for<br />Shopify merchants
      </h1>
      <p class="hero-subtitle">
        Customer insights and inventory intelligence — built to be powerful, priced to be fair.
      </p>
      <div class="hero-actions">
        <a href="/retainpulse" class="hero-cta hero-cta--primary">Explore RetainPulse</a>
        <a href="#stockclock" class="hero-cta hero-cta--secondary">StockClock — Coming Soon</a>
      </div>
    </div>
    <div class="hero-media">
      <img
        src={featureImage.src}
        alt="RetainPulse dashboard showing customer segments"
        width={featureImage.width}
        height={featureImage.height}
        class="hero-image"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(2rem, 5vw, 5.5rem) 0 clamp(1.5rem, 4vw, 4rem);
  }

  .hero-grid {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }

  .hero-media {
    order: -1;
    opacity: 0;
    animation: heroIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }

    .hero-media {
      order: 0;
    }
  }

  .hero-body {
    opacity: 0;
    animation: heroIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .hero-subtitle {
    margin-top: var(--space-md);
    font-size: clamp(1rem, 1.5vw, 1.1875rem);
    color: var(--color-subtext);
    line-height: 1.6;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
  }

  @media (min-width: 480px) {
    .hero-actions {
      flex-direction: row;
      gap: var(--space-md);
    }
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.75rem;
    min-height: 48px;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9375rem;
    transition: all 0.2s ease;
    cursor: pointer;
    white-space: nowrap;
  }

  .hero-cta--primary {
    background: var(--color-accent);
    color: var(--color-surface);
  }

  .hero-cta--primary:hover {
    background: var(--color-accent-hover);
  }

  .hero-cta--secondary {
    background: transparent;
    color: var(--color-text);
    border: 1.5px solid var(--color-border);
  }

  .hero-cta--secondary:hover {
    border-color: var(--color-subtext);
  }

  .hero-image {
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(31, 26, 20, 0.08);
  }

  @keyframes heroIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
