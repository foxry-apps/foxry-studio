---
interface Props {
  title: string;
  description: string;
  platform?: 'shopify' | 'wordpress';
  price?: string;
  ctaText?: string;
  ctaHref?: string;
  badge?: string;
}

const { title, description, platform, price, ctaText, ctaHref, badge } = Astro.props;
---

<article class:list={['card', 'fade-in', platform && `card--${platform}`]}>
  {platform && (
    <span class:list={['platform-label', `platform-label--${platform}`]}>
      {platform === 'shopify' && (
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M15.34 3.8c-.04-.17-.17-.26-.29-.27-.12-.01-2.55-.19-2.55-.19s-1.7-1.68-1.88-1.87c-.18-.18-.54-.13-.68-.08-.02.01-.37.11-.94.29C8.62.74 8.05 0 7.16 0 5.28 0 4.31 2.35 4.02 3.54c-.76.24-1.3.4-1.37.42C2.1 4.12 2.08 4.14 2.04 4.67 2.01 5.08 0 20.95 0 20.95l12.24 2.12L20 21.4s-4.63-17.43-4.66-17.6zM9.27 2.23c-.45.14-.95.3-1.49.46.29-1.1.83-1.63 1.3-1.83.25.49.29 1.14.19 1.37zm-1.7-1.3C7.2 1.14 6.7 1.78 6.43 2.86c-.43.13-.85.26-1.24.38C5.57 1.96 6.34.46 7.57.93zm-.64 6.36s-.53-.28-1.17-.28c-.95 0-1 .59-1 .74 0 .82 2.13 1.13 2.13 3.04 0 1.51-.95 2.47-2.24 2.47-1.54 0-2.33-.96-2.33-.96l.41-1.36s.81.7 1.5.7a.61.61 0 00.64-.61c0-1.07-1.75-1.11-1.75-2.87 0-1.48 1.06-2.91 3.21-2.91.83 0 1.24.24 1.24.24l-.64 1.8zm2.56-5.04c.4.05.66.49.83 1-.32.1-.67.21-1.05.33.2-.78.58-1.27.98-1.33H9.49z"/>
        </svg>
      )}
      {platform === 'wordpress' && (
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.486 2 2 6.486 2 12s4.486 10 10 10 10-4.486 10-10S17.514 2 12 2zM3.5 12c0-1.58.46-3.05 1.24-4.3L9.06 20.1A8.508 8.508 0 013.5 12zm8.5 8.5c-.83 0-1.63-.12-2.39-.34l2.54-7.37 2.6 7.13c.02.04.04.08.06.11-.88.3-1.82.47-2.81.47zm1.1-12.47c.51-.03.97-.08.97-.08.46-.05.4-.73-.05-.7 0 0-1.37.11-2.26.11-.83 0-2.23-.11-2.23-.11-.46-.03-.51.68-.05.7 0 0 .43.06.89.08l1.32 3.61-1.85 5.56-3.08-9.17c.51-.03.97-.08.97-.08.46-.05.4-.73-.05-.7 0 0-1.37.11-2.26.11-.16 0-.35 0-.54-.01A8.48 8.48 0 0112 3.5c2.14 0 4.1.8 5.59 2.11-.04 0-.07-.01-.11-.01-1.09-.15-1.42.95-1.42 1.63 0 .76.44 1.4.9 2.16.35.61.76 1.4.76 2.53 0 .78-.3 1.7-.7 2.96l-.92 3.06-3.3-9.82zm4.14 13.2l2.56-7.4c.48-1.19.63-2.15.63-3 0-.31-.02-.6-.06-.86A8.48 8.48 0 0120.5 12c0 2.98-1.54 5.6-3.86 7.13l-.4.1z"/>
        </svg>
      )}
      {platform === 'shopify' ? 'Shopify' : 'WordPress'}
    </span>
  )}
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  {price && <p class:list={['price', platform && `price--${platform}`]}>{price}</p>}
  {ctaHref && ctaText && (
    <a href={ctaHref} class:list={['cta', platform && `cta--${platform}`]} target="_blank" rel="noopener noreferrer">
      {ctaText}
    </a>
  )}
  {badge && <span class:list={['badge', platform && `badge--${platform}`]}>{badge}</span>}
</article>

<style>
  .card {
    background: var(--color-surface);
    border-radius: 12px;
    padding: var(--space-2xl);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    box-shadow: 0 1px 3px rgba(31, 26, 20, 0.04);
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(31, 26, 20, 0.08);
  }

  .platform-label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    margin-bottom: var(--space-md);
  }

  .platform-label--shopify { color: #6e8e2e; }
  .platform-label--wordpress { color: #1a6080; }

  .platform-label svg { flex-shrink: 0; }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .card-desc {
    margin-top: var(--space-md);
    color: var(--color-subtext);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .price {
    margin-top: var(--space-md);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-accent);
  }

  .price--wordpress { color: #1a6080; }

  .cta {
    display: inline-flex;
    align-items: center;
    margin-top: var(--space-lg);
    padding: 0.75rem 1.5rem;
    min-height: 44px;
    background: var(--color-accent);
    color: var(--color-surface);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.2s ease;
    cursor: pointer;
  }

  .cta:hover { background: var(--color-accent-hover); }

  .cta--shopify {
    background: #6e8e2e;
  }

  .cta--shopify:hover { background: #5c7826; }

  .cta--wordpress {
    background: #1a6080;
  }

  .cta--wordpress:hover { background: #14506b; }

  .badge {
    display: inline-flex;
    align-items: center;
    margin-top: var(--space-lg);
    padding: 0.5rem 1rem;
    min-height: 44px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.7;
    background: rgba(232, 96, 28, 0.08);
    color: var(--color-accent);
  }

  .badge--shopify {
    background: rgba(110, 142, 46, 0.08);
    color: #6e8e2e;
  }
</style>
