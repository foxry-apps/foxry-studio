---
import ScreenshotSlideshow from './ScreenshotSlideshow.astro';
---

<section class="rp fade-in">
  <div class="container">
    <div class="rp-grid">
      <div class="rp-body">
        <h2 class="rp-title">RetainPulse — Customer Segment Insights</h2>
        <p class="rp-desc">
          Spot loyal, at-risk, and dormant customers with industry-adjusted RFM benchmarks.
        </p>
        <ul class="rp-features">
          <li>🎯 8 customer segments scored against real buying cycles</li>
          <li>📊 Health dashboard with month-over-month trends</li>
          <li>📈 Cohort retention analysis</li>
          <li>📋 Action guides for every segment — so you know what to do next</li>
        </ul>
        <p class="rp-price">Free plan available · Pro at $29/mo</p>
        <a
          href="https://apps.shopify.com/retainpulse"
          class="rp-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          View on Shopify App Store →
        </a>
      </div>
      <div class="rp-media">
        <ScreenshotSlideshow />
      </div>
    </div>
  </div>
</section>

<style>
  .rp {
    padding: var(--section-py) 0;
  }

  .rp-grid {
    display: grid;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .rp-grid {
      grid-template-columns: 5fr 7fr;
      align-items: center;
    }
  }

  .rp-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.3;
  }

  .rp-desc {
    margin-top: 0.75rem;
    color: var(--color-subtext);
    line-height: 1.7;
  }

  .rp-features {
    list-style: none;
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.9375rem;
  }

  .rp-price {
    margin-top: 1.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-accent);
  }

  .rp-cta {
    display: inline-block;
    margin-top: 1.25rem;
    padding: 0.75rem 1.5rem;
    min-height: 44px;
    background: var(--color-accent);
    color: var(--color-white);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.2s ease;
    cursor: pointer;
  }

  .rp-cta:hover {
    background: var(--color-accent-hover);
  }
</style>
