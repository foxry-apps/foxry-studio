---
import ProductCard from './ProductCard.astro';
---

<section class="trust">
  <div class="container">
    <h2 class="trust-heading fade-in">Why merchants choose Foxry</h2>
    <div class="trust-grid fade-in">
      <article class="trust-item">
        <h3 class="trust-title">Fair pricing, full features</h3>
        <p class="trust-desc">
          We don't gate essential features behind expensive plans.
          You get what you need without paying enterprise prices.
        </p>
      </article>
      <article class="trust-item">
        <h3 class="trust-title">One app, one job</h3>
        <p class="trust-desc">
          Every app solves a specific problem well.
          No feature bloat, no unnecessary complexity.
        </p>
      </article>
      <article class="trust-item">
        <h3 class="trust-title">Built on modern infrastructure</h3>
        <p class="trust-desc">
          Serverless architecture on Cloudflare means fast performance,
          reliable uptime, and your data stays secure.
        </p>
      </article>
    </div>

    <div class="also fade-in">
      <p class="also-label">We also build for WordPress</p>
      <ProductCard
        title="Foxry Vault — CF7 Submission Storage"
        description="Never lose a Contact Form 7 submission again. Auto-save, GDPR-ready auto-deletion, CSV export."
        platform="wordpress"
        price="Free & open source"
        ctaText="View on WordPress.org →"
        ctaHref="https://wordpress.org/plugins/foxry-vault/"
      />
    </div>
  </div>
</section>

<style>
  .trust {
    padding: var(--section-py) 0;
  }

  .trust-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2xl);
  }

  .trust-grid {
    display: grid;
    gap: var(--space-xl);
  }

  @media (min-width: 640px) {
    .trust-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .trust-item {
    padding: var(--space-lg) 0;
  }

  .trust-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: var(--space-sm);
  }

  .trust-desc {
    color: var(--color-subtext);
    font-size: 0.9375rem;
    line-height: 1.7;
    max-width: 340px;
  }

  .also {
    margin-top: var(--section-py);
  }

  .also-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-md);
  }
</style>
