---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import PricingSection from '../components/PricingSection.astro';
import FaqSection from '../components/FaqSection.astro';
import CtaBanner from '../components/CtaBanner.astro';
import ProductCard from '../components/ProductCard.astro';
import Footer from '../components/Footer.astro';

import appIcon from '../assets/images/csi-app-icon.png';
import ss1 from '../assets/images/retainpulse-ss-1.png';
import ss2 from '../assets/images/retainpulse-ss-2.png';
import ss3 from '../assets/images/retainpulse-ss-3.png';
import ss4 from '../assets/images/retainpulse-ss-4.png';
import ss5 from '../assets/images/retainpulse-ss-5.png';
import ss6 from '../assets/images/retainpulse-ss-6.png';

const features = [
  {
    image: ss1, reverse: false,
    title: "See your store's health at a glance",
    description: "Eight key metrics — from total customers and active rate to average order value and LTV — give you a complete picture of your store. Track segment movements over 1, 7, and 30 days to catch shifts before they become problems.",
  },
  {
    image: ss2, reverse: true,
    title: "Know exactly where every customer stands",
    description: "Your customer base split into 8 clear segments — Champions, Loyal, Potential Loyalists, New, Needs Attention, At Risk, Can't Lose Them, and Dormant. See the composition at a glance and jump to any segment's customer list with one click.",
  },
  {
    image: ss3, reverse: false,
    title: "Track what matters over time",
    description: "Monitor average order value, customer LTV, and repeat purchase rate with 6-month trend charts. Spot growth patterns and catch dips early — all on a single dashboard.",
  },
  {
    image: ss4, reverse: true,
    title: "Measure retention, month by month",
    description: "Cohort retention analysis shows exactly when customers drop off. Compare monthly cohorts side by side to see whether your retention is improving or needs work.",
  },
  {
    image: ss5, reverse: false,
    title: "Dive into individual customers",
    description: "Filter by any segment, sort by last order date or order count, and export to CSV. Every customer row links directly to their Shopify profile.",
  },
  {
    image: ss6, reverse: true,
    title: "Set up in minutes",
    description: "Choose your store type for industry-adjusted benchmarks, enable email and Slack notifications, and you're done. No complex configuration, no onboarding calls.",
  },
];

const faqs = [
  {
    question: "What is RFM analysis?",
    answer: "RFM stands for Recency, Frequency, and Monetary value — three dimensions that score customers based on when they last purchased, how often they buy, and how much they spend. RetainPulse uses RFM scoring with industry-adjusted benchmarks to automatically classify your customers into 8 actionable segments.",
  },
  {
    question: "How are the 8 customer segments defined?",
    answer: "Segments are automatically assigned based on each customer's RFM score. The thresholds adapt to your store type — a furniture store and a consumables store have very different buying cycles, and RetainPulse accounts for that.",
  },
  {
    question: 'What does "industry-adjusted" mean?',
    answer: "Different industries have different purchase patterns. A customer who buys once a year might be loyal for a furniture store but dormant for a grocery store. When you select your Store Type, RetainPulse applies benchmarks calibrated to your industry's typical buying cycle.",
  },
  {
    question: "How often is customer data synced?",
    answer: "Data is synced automatically once per day. Segment assignments, health metrics, and movement tracking are all updated with each daily sync.",
  },
  {
    question: "What's included in the Free plan?",
    answer: "The Free plan supports up to 50 customers and includes the health dashboard, all 8 customer segments, and cohort retention analysis.",
  },
  {
    question: "Can I export customer data?",
    answer: "Yes — on the Pro plan, you can filter customers by segment and export the list as a CSV file.",
  },
  {
    question: "Is my customer data safe?",
    answer: "Your data is processed on Cloudflare's secure global infrastructure. When you uninstall the app, all stored data is deleted. See our Privacy Policy for full details.",
  },
  {
    question: "Which Shopify plans are supported?",
    answer: "RetainPulse works with all Shopify plans — Basic, Shopify, Advanced, and Plus.",
  },
];
---

<Layout
  title="RetainPulse — Customer Segment Insights | Foxry"
  description="Spot loyal, at-risk, and dormant customers with industry-adjusted RFM benchmarks."
>
  <Header />
  <main>
    <section class="rp-hero">
      <div class="container rp-hero-grid">
        <div class="rp-hero-body fade-in">
          <h1 class="rp-hero-title">Customer Segment Insights</h1>
          <p class="rp-hero-desc">
            Spot loyal, at-risk, and dormant customers with industry-adjusted RFM benchmarks.
            Know who to nurture, who to win back, and who's already gone.
          </p>
          <p class="rp-hero-price">Free plan available · Pro at $29/mo</p>
          <a href="https://apps.shopify.com/retainpulse" class="rp-cta" target="_blank" rel="noopener noreferrer">
            View on Shopify App Store →
          </a>
        </div>
        <div class="rp-hero-media fade-in">
          <img src={appIcon.src} alt="RetainPulse app icon" width={appIcon.width} height={appIcon.height} class="rp-app-icon" />
        </div>
      </div>
    </section>
    {features.map((f) => <FeatureBlock image={f.image} title={f.title} description={f.description} reverse={f.reverse} />)}
    <PricingSection />
    <FaqSection items={faqs} />
    <CtaBanner />
    <section class="other-apps fade-in">
      <div class="container">
        <h2 class="other-apps-title">Explore our other tools</h2>
        <div class="other-apps-grid">
          <ProductCard
            title="Foxry Vault — CF7 Submission Storage"
            description="Never lose a Contact Form 7 submission again. Auto-save every entry to your database with GDPR-ready auto-deletion, CSV export, and a dashboard widget."
            platform="wordpress"
            price="Free & open source"
            ctaText="View on WordPress.org →"
            ctaHref="https://wordpress.org/plugins/foxry-vault/"
          />
          <ProductCard
            title="StockClock — Stockout Predictor"
            description="Know when you'll run out of stock — before it happens. Predicts stockout dates from sales velocity and sends alerts via email and Slack."
            platform="shopify"
            badge="Coming to Shopify App Store soon"
          />
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .rp-hero {
    padding: clamp(2rem, 5vw, 5.5rem) 0 clamp(1.5rem, 4vw, 4rem);
  }

  .rp-hero-grid {
    display: grid;
    gap: var(--space-xl);
    text-align: center;
  }

  .rp-hero-media {
    order: -1;
  }

  @media (min-width: 768px) {
    .rp-hero-grid {
      grid-template-columns: 5fr 7fr;
      align-items: center;
      gap: var(--space-3xl);
      text-align: left;
    }

    .rp-hero-media {
      order: 0;
    }
  }

  .rp-hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .rp-hero-desc {
    margin-top: var(--space-md);
    color: var(--color-subtext);
    line-height: 1.7;
    font-size: clamp(1rem, 1.3vw, 1.0625rem);
    max-width: 480px;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .rp-hero-desc {
      margin-inline: 0;
    }
  }

  .rp-hero-price {
    margin-top: var(--space-lg);
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-accent);
    font-size: 0.9375rem;
  }

  .rp-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--space-md);
    padding: 0.875rem 1.75rem;
    min-height: 48px;
    background: var(--color-accent);
    color: var(--color-surface);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.2s ease;
    cursor: pointer;
    width: 100%;
  }

  @media (min-width: 480px) {
    .rp-cta {
      width: auto;
    }
  }

  .rp-cta:hover {
    background: var(--color-accent-hover);
  }

  .rp-hero-media {
    display: flex;
    justify-content: center;
  }

  .rp-app-icon {
    max-width: 160px;
    width: 100%;
    height: auto;
    border-radius: 22%;
    box-shadow: 0 8px 24px rgba(31, 26, 20, 0.1);
  }

  @media (min-width: 768px) {
    .rp-app-icon {
      max-width: 280px;
    }
  }

  .other-apps {
    padding: var(--section-py) 0;
  }

  .other-apps-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .other-apps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .other-apps-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
